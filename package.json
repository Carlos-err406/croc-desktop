{
  "name": "croc-desktop",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "description": "Cross-platform desktop app for the croc secure file transfer tool (Tauri + Vite + React + TS + TailwindCSS + Shadcn/ui)",
  "author": {
    "name": "Carlos Daniel Vilaseca Illnait",
    "email": "carlosvilaseca406@gmail.com"
  },
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tauri build",
    "build:vite": "tsc && vite build",
    "tauri": "tauri",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@choochmeque/tauri-plugin-sharekit-api": "^0.3.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1"
  },
  "devDependencies": {
    "@fontsource/oswald": "^5.3.0",
    "@fontsource/poppins": "^5.3.0",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@tailwindcss/vite": "^4.1.13",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "lucide-react": "^0.476.0",
    "prettier": "^3.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shadcn": "^3.3.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.1.6"
  }
