{
  "name": "croc-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cross-platform desktop app for the croc secure file transfer tool (Electron + Vite + React + TS + TailwindCSS + Shadcn/ui)",
  "author": {
    "name": "Carlos Daniel Vilaseca Illnait",
    "email": "carlosvilaseca406@gmail.com"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build && electron-builder --config electron-builder.json5 --publish=never",
    "build:mac": "tsc && vite build && electron-builder --config electron-builder.json5 --mac --publish=never",
    "build:win": "tsc && vite build && electron-builder --config electron-builder.json5 --win --publish=never",
    "build:linux": "tsc && vite build && electron-builder --config electron-builder.json5 --linux --publish=never",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "prettier --write .",
    "postinstall": "electron-builder install-app-deps && node scripts/fix-node-pty-perms.mjs"
  },
  "dependencies": {
    "@fontsource/oswald": "^5.3.0",
    "@fontsource/poppins": "^5.3.0",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@tailwindcss/vite": "^4.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.476.0",
    "node-pty": "^1.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.6.2",
    "shadcn": "^3.3.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
