{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Croc Desktop",
  "version": "1.1.0",
  "identifier": "dev.carlosd.crocdesktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node scripts/fetch-croc.mjs && npm run dev:vite",
    "beforeBuildCommand": "node scripts/fetch-croc.mjs && npm run build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "Croc Desktop",
        "width": 1120,
        "height": 720,
        "minWidth": 940,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis",
      "appimage",
      "deb"
    ],
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/croc"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "background": "dmg-background.png",
        "windowSize": {
          "width": 600,
          "height": 420
        },
        "appPosition": {
          "x": 160,
          "y": 205
        },
        "applicationFolderPosition": {
          "x": 440,
          "y": 205
        }
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Carlos-err406/croc-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCREFEOTgxQzYyQkU0RjkKUldUNTVDdkdnZG5hZXdOamdNV0lhblg3ZDRBdzdCZGdmMjBSMXhLUjR0Z2d1TDBNRG4rV2tlVGUK"
    }
  }
}
