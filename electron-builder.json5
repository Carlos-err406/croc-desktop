{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "dev.carlosd.crocdesktop",
  "asar": true,
  "productName": "Croc Desktop",
  "compression": "maximum",
  "removePackageScripts": true,
  "directories": {
    "output": "dist-release",
    "buildResources": "build"
  },
  // CI publishes to a DRAFT GitHub Release (per-tag); review + publish manually.
  // Local `npm run build` passes --publish=never, which overrides this.
  "publish": [
    {
      "provider": "github",
      "owner": "Carlos-err406",
      "repo": "croc-desktop",
      "releaseType": "draft"
    }
  ],
  "files": [
    "dist",
    "dist-electron"
  ],
  // node-pty ships a native .node binary; keep it unpacked so it loads from asar.
  "asarUnpack": [
    "**/node_modules/node-pty/**"
  ],
  "mac": {
    // Universal: one binary that runs natively on both Apple Silicon and Intel
    // (no Rosetta, no wrong-arch downloads). electron-builder lipo-merges the
    // native node-pty across arches.
    "target": [
      {
        "target": "dmg",
        "arch": [
          "universal"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "universal"
        ]
      }
    ],
    "artifactName": "${productName}-Mac-${version}-${arch}.${ext}",
    "category": "public.app-category.utilities"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Utility",
    "artifactName": "${productName}-Linux-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "runAfterFinish": true
  },
  // Branded install window: green-gradient background (build/background.tiff)
  // with a drag arrow. Icons sit at the window's vertical center so their
  // placement is independent of the Finder coordinate origin.
  "dmg": {
    "title": "${productName} ${version}",
    "background": "build/background.tiff",
    "iconSize": 120,
    "window": {
      "width": 600,
      "height": 420
    },
    "contents": [
      {
        "x": 170,
        "y": 210,
        "type": "file"
      },
      {
        "x": 430,
        "y": 210,
        "type": "link",
        "path": "/Applications"
      }
    ]
  }
}